{
  "name": "flat-circle",
  "private": true,
  "version": "0.1.0",
  "description": "Flat Circle — security middleware SDK. Don't just guard the wall. Make the interior hostile.",
  "packageManager": "pnpm@9.0.0",
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
